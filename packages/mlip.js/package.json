{
  "name": "@peterspackman/mlip.js",
  "version": "0.1.1",
  "description": "JavaScript/WebAssembly bindings for mlipcpp - Machine Learning Interatomic Potentials",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./dist/index-node.js",
      "browser": "./dist/index.browser.js",
      "default": "./dist/index.browser.js"
    },
    "./cpu": {
      "default": "./dist/cpu/mlipcpp_wasm.js"
    },
    "./gpu": {
      "default": "./dist/gpu/mlipcpp_wasm.js"
    },
    "./cpu-wasm": {
      "default": "./dist/cpu/mlipcpp_wasm.wasm"
    },
    "./gpu-wasm": {
      "default": "./dist/gpu/mlipcpp_wasm.wasm"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:wasm && npm run build:wrapper",
    "build:wasm": "npm run build:wasm:cpu && npm run build:wasm:gpu",
    "build:wasm:cpu": "cd ../.. && BUILD_DIR=wasm-cpu ./scripts/build_wasm.sh",
    "build:wasm:gpu": "cd ../.. && BUILD_DIR=wasm-gpu ./scripts/build_wasm.sh --webgpu --asyncify",
    "build:wrapper": "node scripts/build.js",
    "clean": "rm -rf dist src/mlipcpp_wasm*.js src/mlipcpp_wasm*.wasm src/cpu src/gpu",
    "rebuild": "npm run clean && npm run build",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/peterspackman/mlip.cpp.git",
    "directory": "packages/mlip.js"
  },
  "keywords": [
    "machine-learning",
    "interatomic-potentials",
    "molecular-dynamics",
    "atomistic-simulation",
    "wasm",
    "webassembly",
    "pet",
    "mace",
    "ggml"
  ],
  "author": "Peter Spackman",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/peterspackman/mlip.cpp/issues"
  },
  "homepage": "https://github.com/peterspackman/mlip.cpp#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
